DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash

# 飞书自建应用，用于发群消息和创建云文档
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_CHAT_ID=oc_xxx

# 可填写文件夹 token，也可直接填写飞书文件夹链接
FEISHU_REPORT_FOLDER=https://your-domain.feishu.cn/drive/folder/fldxxxxxxxxxxxx

# 可选：如果你想让文档标题显示项目名
REPORT_BRAND=全球资金流向早报
